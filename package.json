{
  "name": "@dongit/mcp-file-proxy",
  "version": "1.0.0",
  "description": "A stdio-to-HTTP MCP proxy that transparently intercepts file parameters, reading local files and base64-encoding them before forwarding to the remote server.",
  "type": "module",
  "bin": {
    "mcp-file-proxy": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dongit-org/mcp-file-proxy"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "base64-stream": "^1.0.0"
  },
  "devDependencies": {
    "@types/base64-stream": "^1.0.5",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
